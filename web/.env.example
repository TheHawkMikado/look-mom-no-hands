# Copy to .env.local for local dev; set the same names in Vercel for production.
# Never commit the filled-in version.

# --- licence signing -------------------------------------------------------
# Private half from Scripts/gen_license_keypair.sh (32 bytes of hex).
# The PUBLIC half belongs in LicenseConfig.publicKeyHex in the Swift app.
LICENSE_SIGNING_KEY=

# --- database --------------------------------------------------------------
# Any Postgres: Neon, Supabase, RDS. Must allow SSL.
DATABASE_URL=postgres://user:pass@host/db

# --- stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` locally, or the Vercel endpoint's signing secret in prod.
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (price_..., NOT product ids). All three must be RECURRING prices
# billed every 1 week — a one-off price here will fail checkout, which runs in
# subscription mode for every plan.
STRIPE_PRICE_SOLO=price_...        # $3/wk  — 2 computers, 1 phone
STRIPE_PRICE_FAMILY=price_...      # $9/wk  — 9 computers, 9 phones
STRIPE_PRICE_UNLIMITED=price_...   # $27/wk — unlimited + resell rights

# --- email (optional) ------------------------------------------------------
# Without this the licence is still issued and shown on the success page.
RESEND_API_KEY=
LICENCE_FROM="Look Ma, No Hands <licences@nohandsapp.com>"

# --- site ------------------------------------------------------------------
SITE_URL=https://nohandsapp.com
NEXT_PUBLIC_DOWNLOAD_URL=https://github.com/TheHawkMikado/look-mom-no-hands/releases/latest
